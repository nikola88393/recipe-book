# ─── Groq ────────────────────────────────────────────────────────────────────
# Get your free key at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ─── Cloudflare Worker ───────────────────────────────────────────────────────
# Full URL of your deployed Cloudflare Worker
CLOUDFLARE_WORKER_URL=https://recipe-book-proxy.<your-subdomain>.workers.dev
# Shared secret — must match AUTH_SECRET_KEY set via `wrangler secret put AUTH_SECRET_KEY`
CLOUDFLARE_WORKER_SECRET=a-long-random-secret-you-generate

# ─── Firebase Admin SDK ──────────────────────────────────────────────────────
# Paste the full contents of your Firebase service account JSON key (single line)
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then minify and set here, e.g.:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}
FIREBASE_SERVICE_ACCOUNT_JSON=
